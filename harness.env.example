# The URL the IdP under test can reach this SP at. Anchors the SP's entityId,
# ACS URL, and SLO URL — all three are derived from this single value.
# Must be reachable by the IdP: a real domain, or a tunneling URL (e.g. ngrok) for local testing.
BASE_URL=http://localhost:8080

# Host port to expose the harness on.
PORT=8080

# Where the harness's persistent state (SP Credential + IdP Metadata) lives.
# Leave unset to use a Docker-managed named volume (default) — fine for a single machine,
# but not something you can point at directly on the host.
# Set to an absolute path on THIS host to control/migrate it directly, e.g.:
#   macOS/Linux: DATA_PATH=/Users/you/saml-harness-data
#   Windows (Docker Desktop):      DATA_PATH=C:/Users/you/saml-harness-data
# The directory is created automatically on first boot if it doesn't exist.
# DATA_PATH=/absolute/path/on/this/host
